// RxBD - Digital Prescription Platform for Bangladesh
// Prisma Schema with SQLite (Prisma 7 compatible)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Doctor {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  password        String   @default("")
  degrees         String   @default("")
  specialty       String   @default("")
  bmdcNumber      String   @default("")
  phone           String   @default("")
  avatarUrl       String   @default("")
  chamberName     String   @default("")
  chamberAddress  String   @default("")
  chamberPhone    String   @default("")
  chamberEmail    String   @default("")
  emailVerified   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  settings        DoctorSettings?
  patients        Patient[]
  prescriptions   Prescription[]
  subscription    Subscription?
  auditLogs       AuditLog[]
}

model DoctorSettings {
  id                    String   @id @default(cuid())
  doctorId              String   @unique
  letterheadLogoUrl     String   @default("")
  letterheadColor       String   @default("#1a1a2e")
  signatureUrl          String   @default("")
  includeQrCode         Boolean  @default(true)
  defaultLanguage       String   @default("en")
  fontSize              String   @default("medium")
  autoSaveInterval      Int      @default(10)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  doctor                Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Patient {
  id              String   @id @default(cuid())
  doctorId        String
  name            String
  age             String   @default("")
  gender          String   @default("")
  phone           String   @default("")
  address         String   @default("")
  bloodGroup      String   @default("")
  allergies       String   @default("")
  chronicDiseases String   @default("")
  consentGiven    Boolean  @default(false)
  consentDate     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  doctor          Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescriptions   Prescription[]
}

model Prescription {
  id              String   @id @default(cuid())
  doctorId        String
  patientId       String
  date            DateTime @default(now())
  bloodPressure   String   @default("")
  pulse           String   @default("")
  temperature     String   @default("")
  weight          String   @default("")
  spO2            String   @default("")
  diagnosis       String   @default("")
  clinicalNotes   String   @default("")
  advice          String   @default("")
  followUpDate    String   @default("")
  medications     String   @default("[]")
  qrCode          String   @default("")
  pdfUrl          String   @default("")
  status          String   @default("completed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([patientId])
  @@index([date])
}

model Subscription {
  id                String    @id @default(cuid())
  doctorId          String    @unique
  plan              String    @default("free")
  startDate         DateTime  @default(now())
  endDate           DateTime?
  prescriptionsUsed Int       @default(0)
  prescriptionsLimit Int      @default(50)
  paymentMethod     String    @default("")
  transactionId     String    @default("")
  status            String    @default("active")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  doctor            Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model MedicineFeedback {
  id          String   @id @default(cuid())
  doctorId    String
  medicineId  String
  feedbackType String  @default("")
  comment     String   @default("")
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  @@index([doctorId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  doctorId    String
  action      String
  entity      String   @default("")
  entityId    String   @default("")
  details     String   @default("")
  ipAddress   String   @default("")
  createdAt   DateTime @default(now())

  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([action])
  @@index([createdAt])
}
