// RxBD - Digital Prescription Platform for Bangladesh
// Prisma Schema with PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Doctor {
  id             String   @id @default(uuid()) @db.Uuid
  supabaseUid    String   @default("") @map("supabase_uid") @db.Uuid
  email          String   @unique
  name           String   @map("full_name")
  password       String   @default("")
  degrees        String   @default("")
  specialty      String   @default("")
  bmdcNumber     String   @default("") @map("bmdc_number")
  phone          String   @default("")
  avatarUrl      String   @default("") @map("avatar_url")
  chamberName    String   @default("") @map("chamber_name")
  chamberAddress String   @default("") @map("chamber_address")
  chamberPhone   String   @default("") @map("chamber_phone")
  chamberEmail   String   @default("") @map("chamber_email")
  emailVerified  Boolean  @default(false) @map("email_verified")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  settings       DoctorSettings?
  patients       Patient[]
  prescriptions  Prescription[]
  subscription   Subscription?
  auditLogs      AuditLog[]

  @@map("doctors")
}

model DoctorSettings {
  id                String   @id @default(uuid()) @db.Uuid
  doctorId          String   @unique @map("doctor_id") @db.Uuid
  letterheadLogoUrl String   @default("") @map("logo_url")
  letterheadColor   String   @default("#1a1a2e") @map("brand_color")
  signatureUrl      String   @default("") @map("signature_url")
  includeQrCode     Boolean  @default(true) @map("show_qr_code")
  defaultLanguage   String   @default("en") @map("header_template")
  fontSize          String   @default("medium") @map("prescription_theme")
  autoSaveInterval  Int      @default(10) @map("auto_save_interval")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_settings")
}

model Patient {
  id              String    @id @default(uuid()) @db.Uuid
  doctorId        String    @map("doctor_id") @db.Uuid
  name            String
  age             String    @default("") @map("age_years")
  gender          String    @default("")
  phone           String    @default("")
  address         String    @default("")
  bloodGroup      String    @default("") @map("blood_group")
  allergies       String    @default("")
  chronicDiseases String    @default("") @map("chronic_diseases")
  consentGiven    Boolean   @default(false) @map("consent_given")
  consentDate     DateTime? @map("consent_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  doctor        Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([doctorId])
  @@map("patients")
}

model Prescription {
  id              String   @id @default(uuid()) @db.Uuid
  doctorId        String   @map("doctor_id") @db.Uuid
  patientId       String   @map("patient_id") @db.Uuid
  date            DateTime @default(now()) @map("visit_date")
  chiefComplaints String   @default("") @map("chief_complaints")
  bloodPressure   String   @default("") @map("vitals")
  pulse           String   @default("")
  temperature     String   @default("")
  weight          String   @default("")
  spO2            String   @default("")
  onExamination   String   @default("") @map("on_examination")
  investigations  String   @default("") @map("investigations")
  diagnosis       String   @default("")
  diagnosisCode   String   @default("") @map("diagnosis_details")
  clinicalNotes   String   @default("") @map("clinical_notes")
  advice          String   @default("")
  followUpDate    String   @default("") @map("follow_up_date")
  medications     String   @default("[]")
  qrCode          String   @default("") @map("qr_code")
  pdfUrl          String   @default("") @map("pdf_url")
  status          String   @default("completed") @map("is_draft")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  doctor  Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([patientId])
  @@index([date])
  @@map("prescriptions")
}

model Subscription {
  id                String    @id @default(uuid()) @db.Uuid
  doctorId          String    @unique @map("doctor_id") @db.Uuid
  plan              String    @default("free")
  startDate         DateTime  @default(now()) @map("premium_since")
  endDate           DateTime? @map("premium_expires_at")
  prescriptionsUsed Int       @default(0) @map("prescriptions_this_month")
  prescriptionsLimit Int      @default(50)
  paymentMethod     String    @default("") @map("sslcommerz_tran_id")
  transactionId     String    @default("")
  status            String    @default("active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model MedicineFeedback {
  id           String   @id @default(uuid()) @db.Uuid
  doctorId     String   @map("doctor_id") @db.Uuid
  medicineId   String   @map("medicine_name")
  feedbackType String   @default("") @map("feedback_type")
  comment      String   @default("description")
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([doctorId])
  @@index([status])
  @@map("medicine_feedback")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  doctorId  String   @map("doctor_id") @db.Uuid
  action    String
  entity    String   @default("") @map("entity_type")
  entityId  String   @default("") @map("entity_id") @db.Uuid
  details   String   @default("") @map("metadata")
  ipAddress String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}
